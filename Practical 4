    </script>
</body>
</html>


Program 4.5	
Write 	a JS program to demonstrate the concept of Inheritance.
Code:
<!DOCTYPE html>
<head>
</head>
<body>
    <script>
        class Person{
        showDetails(){
document.write("This is a Person<br>")
        }}
class student extends Person {
    study()
    {
        document.write("Student Studies")
    }}
var s1 = new student();
s1.showDetails();
s1.study();
    </script>
</body>
</html>


