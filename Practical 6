<!DOCTYPE html>
<html>
  <head>
     </head>
  <body>
    <h2>Javascript BOM - All Concept OF Timing</h2>
      <button onclick="runOnce()">Run Once</button> 
      <button onclick="startClock()">Start Clock</button>
      
      <p id="clock"></p>
<script>
       function runOnce(){
      setTimeout(function(){
      alert("Hello after 2 seconds");
      },2000);
    }
        function startClock(){
      setInterval(function(){
        document.getElementById("clock").textContent=
        new Date().toLocaleTimeString();
      },1000);
    }
</script>
  </body>
</html>


