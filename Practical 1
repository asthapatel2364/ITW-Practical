Program 1.4
To study JavaScript variables and data types.
Code:
<!DOCTYPE html>
<head></head>
<body>
    <script>
        let name = "Astha";
        let age = "17";
        const isStudent = true;
        document.write("Name: " + name + "<br>");
        document.write("Age: " + age + "<br>");
        document.write("Student: " + typeof(name) + "<br>");
        document.write("Type of Name: " + typeof(name) + "<br>");
        document.write("Type of Age: " + typeof(age) + "<br>");
        document.write("Type of Student: " + typeof(isStudent));
     </script>
</body>
</html>


